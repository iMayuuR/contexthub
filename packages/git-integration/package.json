{
  "name": "@contexthub/git-integration",
  "version": "1.0.0",
  "description": "Git integration for ContextHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iMayuuR/contexthub.git",
    "directory": "packages/git-integration"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@contexthub/core": "^1.0.0",
    "@contexthub/shared-types": "^1.0.0",
    "simple-git": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "author": "Mayur Dattatray Patil",
  "bugs": {
    "url": "https://github.com/iMayuuR/contexthub/issues"
  },
  "homepage": "https://github.com/iMayuuR/contexthub#readme",
  "keywords": [
    "contexthub",
    "mcp",
    "ai-memory",
    "cursor",
    "claude"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
