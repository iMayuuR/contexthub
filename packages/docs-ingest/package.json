{
  "name": "@imayuur/contexthub-docs-ingest",
  "version": "1.0.2",
  "description": "Markdown document ingest engine for ContextHub",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "glob": "^10.0.0",
    "@imayuur/contexthub-core": "^1.0.2",
    "@imayuur/contexthub-vector-engine": "^1.0.2",
    "@imayuur/contexthub-knowledge-graph": "^1.0.2"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "author": "Mayur Dattatray Patil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iMayuuR/contexthub.git",
    "directory": "packages/docs-ingest"
  },
  "bugs": {
    "url": "https://github.com/iMayuuR/contexthub/issues"
  },
  "homepage": "https://github.com/iMayuuR/contexthub#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "contexthub",
    "mcp",
    "ai-memory",
    "cursor",
    "claude"
