{
  "name": "@imayuur/contexthub-knowledge-graph",
  "version": "1.0.1",
  "description": "Code knowledge graph builder and query engine for ContextHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iMayuuR/contexthub.git",
    "directory": "packages/knowledge-graph"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc && node --test dist/__tests__/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@imayuur/contexthub-shared-types": "^1.0.1",
    "@imayuur/contexthub-core": "^1.0.1",
    "@imayuur/contexthub-repo-parser": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "author": "Mayur Dattatray Patil",
  "bugs": {
    "url": "https://github.com/iMayuuR/contexthub/issues"
  },
  "homepage": "https://github.com/iMayuuR/contexthub#readme",
  "keywords": [
    "contexthub",
    "mcp",
    "ai-memory",
    "cursor",
    "claude"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
