{
  "name": "@imayuur/contexthub",
  "version": "1.0.2",
  "description": "ContextHub MCP server launcher — setup, start, stop, and memory management",
  "author": "Mayur Dattatray Patil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iMayuuR/contexthub.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/iMayuuR/contexthub/issues"
  },
  "homepage": "https://github.com/iMayuuR/contexthub#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "contexthub": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md"
  ],
  "keywords": [
    "contexthub",
    "mcp",
    "ai-memory",
    "cursor",
    "claude"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/templates','dist/templates',{recursive:true})\"",
    "dev": "tsc --watch",
    "test": "tsc && node --test dist/__tests__/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "commander": "^10.0.0",
    "inquirer": "^9.0.0",
    "ora": "^6.0.0",
    "@imayuur/contexthub-core": "^1.0.2",
    "@imayuur/contexthub-mcp-server": "^1.0.2",
    "@imayuur/contexthub-shared-types": "^1.0.2",
    "@imayuur/contexthub-vector-engine": "^1.0.2",
    "@imayuur/contexthub-knowledge-graph": "^1.0.2",
    "@imayuur/contexthub-docs-ingest": "^1.0.2",
    "@imayuur/contexthub-git-integration": "^1.0.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
